# Telegram
TELEGRAM_BOT_TOKEN=put_telegram_token_here

# VK
VK_GROUP_TOKEN=put_vk_group_token_here
VK_GROUP_ID=put_vk_group_id_here

# App
APP_ENV=production
LOG_LEVEL=INFO
PORT=8080
STORAGE_BACKEND=sqlite
SQLITE_STORAGE_PATH=data/players.sqlite3
# Старый JSON нужен только для автопереноса существующих игроков в SQLite
PLAYERS_STORAGE_PATH=data/players.json

# Telegram polling/network timeouts for cloud platforms
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=30
TELEGRAM_GET_UPDATES_CONNECT_TIMEOUT=30
TELEGRAM_GET_UPDATES_READ_TIMEOUT=60
TELEGRAM_GET_UPDATES_WRITE_TIMEOUT=30
TELEGRAM_GET_UPDATES_POOL_TIMEOUT=30
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_BOOTSTRAP_RETRIES=-1

# Website links used by bot messages
SITE_PROFILE_BASE_URL=https://your-domain.ru/profile
SITE_PAVILION_URL=https://your-domain.ru/pavilion
