# Telegram
TELEGRAM_BOT_TOKEN=put_real_telegram_bot_token_here
# If the same Telegram token is still running in another app/container,
# the new container will keep the website alive and retry polling.
TELEGRAM_RETRY_ON_CONFLICT=true
TELEGRAM_CONFLICT_RETRY_SECONDS=30
TELEGRAM_DROP_PENDING_UPDATES=false

# VK
VK_GROUP_TOKEN=put_real_vk_group_token_here
VK_GROUP_ID=put_real_vk_group_id_here
VK_RESTART_ON_ERROR=true
VK_RESTART_RETRY_SECONDS=30

# Admin chat / panel
# Узнать значения можно командой /admin_id в нужном Telegram-чате и VK-беседе.
TELEGRAM_ADMIN_CHAT_IDS=123456789,-1001234567890
TELEGRAM_ADMIN_USER_IDS=111111111,222222222
VK_ADMIN_PEER_IDS=2000000001
VK_ADMIN_USER_IDS=111111111,222222222
PROMO_CODES_PATH=data/promo_codes.json  # JSON fallback only; SQLite/PostgreSQL store promo codes in DB.
ADMIN_AUDIT_LOG_PATH=data/admin_audit.log
ADMIN_BACKUP_DIR=data/admin_backups

# App / Timeweb
APP_ENV=production
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8080
PORT=8080

# Logs
# Use off/none/- to disable file logging locally.
LOG_FILE_PATH=logs/ner_talis.log

# Storage
# Local/test default: copy-paste works without PostgreSQL.
# For Timeweb production use STORAGE_BACKEND=postgres and a real DATABASE_URL.
STORAGE_BACKEND=sqlite
# DATABASE_URL=postgresql://real_user:real_password@real_host:5432/real_db
SQLITE_STORAGE_PATH=data/players.sqlite3
# Old JSON is used only for auto-migration of existing players into SQLite/PostgreSQL.
PLAYERS_STORAGE_PATH=data/players.json

# Backups for SQLite local mode
SQLITE_BACKUP_DIR=backups
SQLITE_BACKUP_KEEP_DAYS=14

# Website links used by bot messages
SITE_BASE_URL=https://ner-talis-game.ru
SITE_PROFILE_BASE_URL=https://ner-talis-game.ru/profile
SITE_PAVILION_URL=https://ner-talis-game.ru/pavilion
WEB_SESSION_SECRET=change_me_to_long_random_string
WEB_SESSION_TTL_MINUTES=1440

# Runtime timers
# How often each container scans DB for finished timers; DB claims prevent duplicate messages.
TIMER_RECOVERY_INTERVAL_SECONDS=30

# Optional website/API
API_BASE_URL=https://ner-talis-game.ru/api

# Safety valve only for manual emergency/debug runs. Keep false in production.
ALLOW_JSON_STORAGE_IN_PRODUCTION=false
